{
	"compilerOptions": {
		"target": "ESNext",
		"lib": [
			"ESNext"
		],
		"module": "NodeNext",
		"moduleResolution": "NodeNext",
		"removeComments": true,
		"noEmitOnError": true,
		"allowSyntheticDefaultImports": true,
		"esModuleInterop": true,
		"forceConsistentCasingInFileNames": true,
		"strict": true,
		"noUnusedLocals": true,
		"noUnusedParameters": true,
		"noFallthroughCasesInSwitch": true,
		"skipDefaultLibCheck": true,
		"skipLibCheck": true,
		"allowJs": true,
		"checkJs": false,
        "noImplicitAny": false,
		"experimentalDecorators": true,
		"emitDecoratorMetadata": true,
		"noErrorTruncation": true,
		"sourceMap": true,
		"alwaysStrict": true,
		"incremental": true,
		"outDir": "./dist",
		"baseUrl": "./",
		"rootDir": "./src",
		"paths": {
			"@enderbot/types": ["./src/types/enderbot"],
			"@enderbot/client": ["./src/structures/Client"],
			"@enderbot/errors": ["./src/structures/classes/Errors"],
			"@enderbot/functions": ["./src/structures/utils/functions"],
			"@enderbot/utils/*": ["./src/structures/utils/*"],
			"@enderbot/classes/*": ["./src/structures/classes/*"],
            "@enderbot/Schemas/*": ["./src/Schemas/*"]
		}
	},
	"ts-node": {
		"outDir": "./dist",
		"rootDir": "./src",
		"baseUrl": "./",
		"paths": {
			"@enderbot/types": ["./src/types/enderbot.ts"],
			"@enderbot/client": ["./src/structures/Client.ts"],
			"@enderbot/errors": ["./src/structures/classes/Errors.ts"],
			"@enderbot/functions": ["./src/structures/utils/functions.ts"],
			"@enderbot/utils/*": ["./src/structures/utils/*"],
			"@enderbot/classes/*": [":/src/structures/classes/*"]
		}
	},
	"include": [
		"./src/**/*",
		"env.d.ts"
	],
	"exclude": [
		"node_modules",
		"package-lock.json",
		".gitignore"
	],
}